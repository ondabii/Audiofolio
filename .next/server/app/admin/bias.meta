{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/admin/layout,_N_T_/admin/[alias]/layout,_N_T_/admin/[alias]/page,_N_T_/admin/bias"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/admin/$d$alias/__PAGE__",
    "/admin/$d$alias",
    "/admin",
    "/_index",
    "/_head"
  ]
}