{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/[alias]/layout,_N_T_/[alias]/page,_N_T_/bias"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/$d$alias/__PAGE__",
    "/$d$alias",
    "/_index",
    "/_head"
  ]
}